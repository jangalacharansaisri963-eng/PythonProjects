name: Build Scientific Calculator

on:
  push:
  pull_request:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install compiler
        run: |
          sudo apt-get update
          sudo apt-get install -y g++

      - name: Build Scientific Calculator
        run: |
          g++ \
            C++/ScientificCalculator/src/main.cpp \
            C++/ScientificCalculator/src/Engine.cpp \
            C++/ScientificCalculator/src/Parser.cpp \
            C++/ScientificCalculator/src/Tokenizer.cpp \
            C++/ScientificCalculator/src/FunctionLibrary.cpp \
            C++/ScientificCalculator/src/functions/Arithmetic.cpp \
            C++/ScientificCalculator/src/functions/Roots.cpp \
            C++/ScientificCalculator/src/functions/Powers.cpp \
            C++/ScientificCalculator/src/functions/Trigonometry.cpp \
            C++/ScientificCalculator/src/functions/Hyperbolic.cpp \
            C++/ScientificCalculator/src/functions/Logarithms.cpp \
            C++/ScientificCalculator/src/functions/Factorial.cpp \
            C++/ScientificCalculator/src/functions/Random.cpp \
            C++/ScientificCalculator/src/functions/Memory.cpp \
            -std=c++17 \
            -Wall \
            -Wextra \
            -pedantic \
            -o calculator

      - name: Upload executable
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: ScientificCalculator
          path: calculator
